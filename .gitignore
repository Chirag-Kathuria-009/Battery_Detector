BatteryDataset/**/*.jpeg
BatteryDataset/**/*.png
BatteryDataset/**/*.bmp
BatteryDataset/**/*.webp
# YOLO label files live in labels/ folders alongside each split
BatteryDataset/**/labels/

# Dataset archives & trained model weights (large binaries — keep out of git)
BatteryDataset/**/*.zip
*.pt

